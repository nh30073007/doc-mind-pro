# Groq API Configuration (সক্রিয়)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant

# Common API Parameters
MAX_TOKENS=1024
TEMPERATURE=0.2

# Embedding Model (দ্রুত প্রসেসিংয়ের জন্য)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG Parameters
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RESULTS=3